# DeepCamera JVH Backend Configuration

# Server
PORT=3100
NODE_ENV=production

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deepcamera_jvh
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production_min_32_chars

# MQTT Broker
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_PROTOCOL=mqtt

# Admin user (initial setup)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@jvhsoporte.cl
ADMIN_PASSWORD=JVHadmin2026

# Environment
LOG_LEVEL=info
